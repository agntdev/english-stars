[
  {
    "name": "Admin grant — invalid user ID rejected",
    "steps": [
      {
        "send": { "text": "/admin", "userId": 42 },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "🔧 Admin Panel" }
          }
        ]
      },
      {
        "send": { "callback": "admin:grant", "userId": 42 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "sendMessage",
            "payload": { "text": "Send the user ID to grant access to:" }
          }
        ]
      },
      {
        "send": { "text": "not-a-number", "userId": 42 },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Invalid user ID. Please send a numeric user ID." }
          }
        ]
      }
    ]
  },
