[
  {
    "name": "successful payment sends admin notification with user info and transaction ID",
    "steps": [
      {
        "send": {
          "update": {
            "update_id": 1,
            "message": {
              "message_id": 1,
              "date": 0,
              "chat": { "id": 100, "type": "private" },
              "from": { "id": 100, "is_bot": false, "first_name": "Alice", "username": "alice_dev" },
              "successful_payment": {
                "currency": "XTR",
                "total_amount": 10,
                "invoice_payload": "buy_stars_10",
                "telegram_payment_charge_id": "txn-admin-abc123",
                "provider_payment_charge_id": "provider-xyz"
              }
            }
          }
        },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Payment received! You now have 10 stars." }
          },
          {
            "method": "sendMessage",
            "payload": { "text": "Your account is now unlocked! 🎉" }
          },
          {
            "method": "sendMessage",
            "payload": {
              "chat_id": 999999,
              "text": "New purchase!\nUser: Alice (ID: 100, @alice_dev)\nTransaction: txn-admin-abc123"
            }
          }
        ]
      }
    ]
  },
