            }
          }
        ]
      }
    ]
  },
  {
    "name": "Play audio button sends pronunciation guide",
    "steps": [
      {
        "send": { "callback": "word:audio:Ephemeral" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "sendMessage",
            "payload": {
              "text": "🔊 Pronunciation for *Ephemeral*: /ih-FEM-er-ul/"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Last word shows only Prev and Play audio",
